[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/PauseMenu.gd" id="1_pause"]

[node name="PauseMenu" type="Control"]
process_mode = 3
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_pause")

[node name="Dim" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0, 0, 0, 0.6)

[node name="VBox" type="VBoxContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -140.0
offset_top = -120.0
offset_right = 140.0
offset_bottom = 120.0
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "PAUSED"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 40

[node name="Resume" type="Button" parent="VBox"]
layout_mode = 2
text = "RESUME"

[node name="Restart" type="Button" parent="VBox"]
layout_mode = 2
text = "RESTART"

[node name="Menu" type="Button" parent="VBox"]
layout_mode = 2
text = "MAIN MENU"

[connection signal="pressed" from="VBox/Resume" to="." method="_on_resume_pressed"]
[connection signal="pressed" from="VBox/Restart" to="." method="_on_restart_pressed"]
[connection signal="pressed" from="VBox/Menu" to="." method="_on_menu_pressed"]
