[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/CreditsScreen.gd" id="1_cr"]

[node name="Credits" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_cr")

[node name="BG" type="ColorRect" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.06, 0.12, 1)

[node name="VBox" type="VBoxContainer" parent="."]
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -300.0
offset_top = -160.0
offset_right = 300.0
offset_bottom = 160.0
theme_override_constants/separation = 8

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "CREDITS"
horizontal_alignment = 1
theme_override_font_sizes/font_size = 40

[node name="Engine" type="Label" parent="VBox"]
layout_mode = 2
text = "Built with Godot Engine 4"
horizontal_alignment = 1

[node name="Team" type="Label" parent="VBox"]
layout_mode = 2
text = "Design, Code & Art: Neon Dash Contributors"
horizontal_alignment = 1

[node name="License" type="Label" parent="VBox"]
layout_mode = 2
text = "Released under the MIT License. See docs/CREDITS.md for full asset attributions."
horizontal_alignment = 1
autowrap_mode = 2

[node name="Back" type="Button" parent="VBox"]
layout_mode = 2
text = "BACK"

[connection signal="pressed" from="VBox/Back" to="." method="_on_back_pressed"]
